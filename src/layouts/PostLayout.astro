---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  cover?: string;
}
const { title, description, date, cover } = Astro.props;
const dateLabel = date.toLocaleDateString('en-GB', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
const dateISO = date.toISOString().slice(0, 10);
---
<BaseLayout title={`${title} — Ross Wilson`} description={description} ogImage={cover}>
  <header slot="header" class="relative bg-ink text-white overflow-hidden">
    <SiteHeader />
    {cover && (
      <>
        <img
          src={cover}
          alt=""
          class="absolute inset-0 w-full h-full object-cover opacity-40"
        />
        <div class="absolute inset-0 bg-black/30"></div>
      </>
    )}
    <div class="relative max-w-3xl mx-auto px-6 py-24 text-center">
      <h1 class="text-4xl md:text-5xl font-bold">{title}</h1>
      <p class="mt-3 text-white/80 text-base">
        By Ross Wilson on <time datetime={dateISO}>{dateLabel}</time>
      </p>
    </div>
  </header>
  <article class="prose prose-lg font-serif prose-headings:font-sans mx-auto px-6 py-12 max-w-3xl">
    <slot />
  </article>
</BaseLayout>
