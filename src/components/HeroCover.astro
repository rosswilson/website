---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  subtitle?: string;
  image: ImageMetadata;
}
const { title, subtitle, image } = Astro.props;
---
<header class="relative min-h-[50vh] flex items-center justify-center overflow-hidden bg-ink text-white">
  <Image
    src={image}
    alt=""
    widths={[600, 1200, 1600, 2000]}
    sizes="100vw"
    fetchpriority="high"
    loading="eager"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover opacity-50"
  />
  <div class="absolute inset-0 bg-black/30"></div>
  <slot name="nav">
    <!-- consumer can override; default below -->
  </slot>
  <div class="relative z-10 text-center px-6 py-24">
    <h1 class="text-5xl md:text-6xl font-bold">{title}</h1>
    {subtitle && <p class="mt-4 font-serif text-2xl md:text-3xl text-white/85">{subtitle}</p>}
  </div>
</header>
