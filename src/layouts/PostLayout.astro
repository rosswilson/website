---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  cover?: string;
}
const { title, description, date, cover } = Astro.props;
const dateLabel = date.toLocaleDateString('en-GB', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
const dateISO = date.toISOString().slice(0, 10);
---
<BaseLayout title={`${title} — Ross Wilson`} description={description} ogImage={cover}>
  <header slot="header" class="relative bg-ink text-white overflow-hidden min-h-[50vh] flex">
    <SiteHeader />
    {cover && (
      <>
        <img
          src={cover}
          alt=""
          fetchpriority="high"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover opacity-50"
        />
        <div class="absolute inset-0 bg-black/30"></div>
      </>
    )}
    <div class="relative max-w-3xl mx-auto px-6 py-24 flex-1 flex flex-col items-center justify-center text-center">
      <h1 class="text-4xl md:text-5xl font-bold">{title}</h1>
      <div class="mt-6 flex items-center justify-center gap-3">
        <img
          src="/images/ross-wilson.webp"
          alt=""
          class="w-10 h-10 rounded-full object-cover ring-2 ring-white/30"
        />
        <p class="text-base text-white/85">
          By Ross Wilson on <time datetime={dateISO}>{dateLabel}</time>
        </p>
      </div>
    </div>
  </header>
  <article class="prose prose-lg font-serif prose-headings:font-sans mx-auto px-6 py-12 max-w-3xl">
    <slot />
  </article>
</BaseLayout>
